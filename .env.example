# Server Configuration
# PORT: The port your server will run on (e.g., 5000)
PORT=5000

# NODE_ENV: Environment mode (e.g., development, production)
NODE_ENV=development

# CLIENT_URL: The URL of your frontend application (e.g., http://localhost:3000)
CLIENT_URL=http://localhost:3000

# Firebase Configuration
# FIREBASE_PROJECT_ID: Get this from Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=

# FIREBASE_CLIENT_EMAIL: Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_CLIENT_EMAIL=

# FIREBASE_PRIVATE_KEY: Get this from the generated private key JSON file in Firebase Console
FIREBASE_PRIVATE_KEY=

# Supabase Configuration
# SUPABASE_URL: Get this from Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=

# SUPABASE_SERVICE_KEY: Get this from Supabase Dashboard > Project Settings > API > service_role secret
SUPABASE_SERVICE_KEY=

# Razorpay Configuration
# RAZORPAY_KEY_ID: Get this from Razorpay Dashboard > Settings > API Keys > Key Id
RAZORPAY_KEY_ID=

# RAZORPAY_KEY_SECRET: Get this from Razorpay Dashboard > Settings > API Keys > Key Secret
RAZORPAY_KEY_SECRET=

# RAZORPAY_WEBHOOK_SECRET: Create this secret when setting up webhooks in Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=
